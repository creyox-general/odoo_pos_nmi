<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- POS terminal list view -->
        <record id="pos_terminal_tree_view" model="ir.ui.view">
            <field name="name">pos.terminal.tree.view</field>
            <field name="model">pos.terminal</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="device_id" string="POI Device ID"/>
                    <field name="serial_number"/>
                    <field name="device_make"/>
                    <field name="device_model_name" string="Model"/>
                    <field name="device_status" widget="badge"
                           decoration-success="device_status == 'available'"
                           decoration-warning="device_status == 'unknown'"
                           decoration-danger="device_status in ('error', 'unavailable')"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- POS terminal form view -->
        <record id="pos_terminal_form_view" model="ir.ui.view">
            <field name="name">pos.terminal.form.view</field>
            <field name="model">pos.terminal</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="device_status" widget="statusbar"
                               statusbar_visible="unknown,available,unavailable,error"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="e.g. Front Counter Terminal"/>
                            </h1>
                        </div>

                        <group>
                            <group name="device_info" string="Device Hardware Details">
                                <field name="device_id" string="POI Device ID" readonly="1"/>
                                <field name="serial_number"/>
                                <field name="device_make"/>
                                <field name="device_model_name" string="Device Model"/>
                            </group>
                            <group name="status_info" string="Status Information">
                                <field name="last_test_date"/>
                                <field name="last_test_result"/>
                                <field name="active"/>
                            </group>
                        </group>

                        <notebook>
                            <page id="legacy_config" string="Legacy Settings" invisible="True">
                                <group>
                                    <group string="Legacy connection details (kept for backward compatibility)">
                                        <field name="connection_type"/>
                                        <field name="device_model"/>
                                        <field name="com_port"/>
                                        <field name="baudrate"/>
                                        <field name="ip_address"/>
                                        <field name="tcp_port"/>
                                        <field name="server_address"/>
                                        <field name="server_port"/>
                                        <field name="standby_message"/>
                                        <field name="timeout"/>
                                        <field name="auto_confirm"/>
                                        <field name="print_receipt"/>
                                        <field name="merchant_name"/>
                                        <field name="merchant_address"/>
                                        <field name="merchant_phone"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- POS terminal action -->
        <record id="action_pos_terminal" model="ir.actions.act_window">
            <field name="name">NMI POS Terminals</field>
            <field name="res_model">pos.terminal</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- POS terminal menu item under Configurations -->
        <menuitem id="menu_pos_terminal"
                  name="NMI POS Terminals"
                  parent="point_of_sale.menu_point_config_product"
                  action="action_pos_terminal"
                  sequence="4"
                  groups="point_of_sale.group_pos_manager"/>
    </data>
</odoo>